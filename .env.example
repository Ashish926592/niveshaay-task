# ──────────────────────────────────────────────────────────────────────────
# Niveshaay Financial Results Pipeline — environment variables
# Copy this file to `.env` and fill in your values. NEVER commit `.env`.
# These are read by the n8n container (docker-compose `env_file`) and referenced
# inside the workflow as {{ $env.VAR_NAME }} — so no secret ever lives in workflow.json.
# ──────────────────────────────────────────────────────────────────────────

# REQUIRED — Google Gemini API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL — WhatsApp delivery via Evolution API.
# Leave WHATSAPP_GROUP_JID EMPTY to skip WhatsApp entirely (the form still returns JSON).
EVOLUTION_API_URL=http://evolution:8080
EVOLUTION_API_KEY=change-me
EVOLUTION_INSTANCE=niveshaay
WHATSAPP_GROUP_JID=

# REQUIRED: let nodes read env vars in expressions (the Gemini node uses
# {{ $env.GEMINI_API_KEY }}). n8n blocks this by default -> "access to env vars denied".
N8N_BLOCK_ENV_ACCESS_IN_NODE=false

# Allow n8n to load the community Puppeteer node and to read env vars in expressions.
N8N_COMMUNITY_PACKAGES_ENABLED=true
N8N_COMMUNITY_PACKAGES_ALLOW_TOOL_USAGE=true
# Chromium path inside the custom n8n image (see Dockerfile.n8n)
N8N_PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium-browser

    {
      "parameters": {
        "httpMethod": "POST",
        "path": "process-pdf",
        "responseMode": "responseNode",
        "options": {}
      },
      "id": "nv-0003",
      "name": "Webhook Process",
      "type": "n8n-nodes-base.webhook",
      "typeVersion": 2,
      "position": [
        240,
        420
      ],
      "webhookId": "process-pdf"
    },
    {
      "parameters": {
        "jsCode": "const b = $input.first().json.body || $input.first().json;\nconst pdfUrl = String((b && b.pdfUrl) || \"\").trim();\nif (!pdfUrl) return [{ json: { error: true, message: \"PDF URL is required\", statusCode: 400 } }];\nif (!pdfUrl.startsWith(\"https://\")) return [{ json: { error: true, message: \"URL must start with https://\", statusCode: 400 } }];\nif (!pdfUrl.toLowerCase().includes(\".pdf\")) return [{ json: { error: true, message: \"URL must point to a PDF file (.pdf)\", statusCode: 400 } }];\nreturn [{ json: { pdfUrl, error: false } }];"
      },
      "id": "nv-0004",
      "name": "Validate Input",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        460,
        420
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "c",
              "leftValue": "={{ $json.error }}",
              "rightValue": "true",
              "operator": {
                "type": "boolean",
                "operation": "equals",
                "singleValue": true
              }
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "nv-0005",
      "name": "Is Valid?",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2,
      "position": [
        680,
        420
      ]
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ error: $json.message || \"Invalid request\" }) }}",
        "options": {
          "responseCode": "={{ $json.statusCode || 400 }}",
          "responseHeaders": {
            "entries": [
              {
                "name": "Access-Control-Allow-Origin",
                "value": "*"
              }
            ]
          }
        }
      },
      "id": "nv-0006",
      "name": "Validation Error",

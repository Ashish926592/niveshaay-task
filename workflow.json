{
  "id": "niveshaayfinres1",
  "name": "Niveshaay — Financial Results Processor (UI + API)",
  "nodes": [
    {
      "parameters": {
        "httpMethod": "GET",
        "path": "ui",
        "responseMode": "responseNode",
        "options": {}

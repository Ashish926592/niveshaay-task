      "id": "nv-0007",
      "name": "Download PDF",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        900,
        420
      ],
      "onError": "continueErrorOutput"
    },
    {
      "parameters": {
        "respondWith": "json",
        "responseBody": "={{ JSON.stringify({ error: \"Failed to download the PDF. The link may be invalid, expired, or blocked.\" }) }}",
        "options": {
          "responseCode": 502,

    },
    {
      "parameters": {
        "respondWith": "text",
        "responseBody": "<!DOCTYPE html>\n<html lang=\"en\">\n<head>\n  <meta charset=\"utf-8\" />\n  <meta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\" />\n  <title>Niveshaay · Financial Results Processor</title>\n  <link rel=\"preconnect\" href=\"https://fonts.googleapis.com\" />\n  <link href=\"https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap\" rel=\"stylesheet\" />\n  <script src=\"https://cdnjs.cloudflare.com/ajax/libs/html2canvas/1.4.1/html2canvas.min.js\"></script>\n  <style>\n    :root{\n      --green-900:#0f3d1e; --green-800:#1b5e20; --green-700:#2e7d32; --green-100:#e8f5e9;\n      --ink:#10231a; --muted:#5b6b62; --line:#e3e9e5; --bg:#f5f8f6; --card:#ffffff;\n      --red:#d32f2f; --shadow:0 10px 30px rgba(16,35,26,.08);\n    }\n    *{box-sizing:border-box;margin:0;padding:0}\n    body{font-family:Inter,system-ui,Segoe UI,Arial,sans-serif;background:var(--bg);color:var(--ink);line-height:1.5;-webkit-font-smoothing:antialiased}\n    .wrap{max-width:980px;margin:0 auto;padding:0 20px 64px}\n    /* header */\n    header{background:linear-gradient(135deg,var(--green-900),var(--green-700));color:#fff;padding:26px 0 30px;box-shadow:var(--shadow)}\n    .brand{max-width:980px;margin:0 auto;padding:0 20px;display:flex;align-items:center;gap:14px}\n    .logo{width:42px;height:42px;border-radius:11px;background:rgba(255,255,255,.16);display:grid;place-items:center;font-size:22px}\n    .brand h1{font-size:20px;font-weight:800;letter-spacing:.3px}\n    .brand p{font-size:12.5px;color:#cfe8d3;font-weight:500;margin-top:1px}\n    /* card */\n    .panel{background:var(--card);border:1px solid var(--line);border-radius:16px;box-shadow:var(--shadow);padding:24px;margin-top:-18px}\n    .panel.lift{margin-top:24px}\n    label.fl{display:block;font-size:13px;font-weight:600;color:var(--muted);margin-bottom:8px}\n    .row{display:flex;gap:10px;flex-wrap:wrap}\n    input[type=url],input[type=text]{flex:1;min-width:240px;padding:13px 14px;border:1.5px solid var(--line);border-radius:11px;font-size:14px;font-family:inherit;outline:none;transition:border-color .15s,box-shadow .15s}\n    input:focus{border-color:var(--green-700);box-shadow:0 0 0 3px var(--green-100)}\n    button{font-family:inherit;cursor:pointer;border:none;border-radius:11px;font-weight:600;font-size:14px;transition:transform .05s,filter .15s,background .15s}\n    button:active{transform:translateY(1px)}\n    .btn-primary{background:var(--green-700);color:#fff;padding:13px 22px}\n    .btn-primary:hover{filter:brightness(1.06)}\n    .btn-primary:disabled{opacity:.6;cursor:not-allowed}\n    .btn-ghost{background:var(--green-100);color:var(--green-800);padding:9px 14px;font-size:13px}\n    .btn-ghost:hover{filter:brightness(.98)}\n    .samples{margin-top:14px;font-size:12.5px;color:var(--muted)}\n    .samples a{color:var(--green-700);text-decoration:none;font-weight:600;cursor:pointer;border-bottom:1px dashed var(--green-100)}\n    .samples a:hover{border-bottom-color:var(--green-700)}\n    .hint{font-size:12px;color:var(--muted);margin-top:10px}\n    /* loading */\n    .loader{display:none;text-align:center;padding:36px 0}\n    .spinner{width:46px;height:46px;border:4px solid var(--green-100);border-top-color:var(--green-700);border-radius:50%;margin:0 auto 16px;animation:spin 1s linear infinite}\n    @keyframes spin{to{transform:rotate(360deg)}}\n    .stage{font-size:14px;font-weight:600;color:var(--green-800)}\n    .stage small{display:block;color:var(--muted);font-weight:500;margin-top:4px}\n    /* result */\n    #result{display:none}\n    .resbar{display:flex;align-items:center;gap:12px;flex-wrap:wrap;margin-bottom:16px}\n    .company{font-size:19px;font-weight:800}\n    .badge{font-size:11px;font-weight:700;text-transform:uppercase;letter-spacing:.5px;padding:4px 10px;border-radius:999px;background:var(--green-100);color:var(--green-800)}\n    .spacer{flex:1}\n    .tabs{display:flex;gap:6px;background:#eef3f0;padding:5px;border-radius:12px;width:fit-content;margin-bottom:16px}\n    .tab{padding:8px 16px;border-radius:9px;font-size:13px;font-weight:600;color:var(--muted);background:transparent}\n    .tab.active{background:#fff;color:var(--green-800);box-shadow:0 1px 4px rgba(0,0,0,.06)}\n    .view{display:none}\n    .view.active{display:block}\n    /* P&L card / table */\n    .pnl{border:1.5px solid var(--green-700);border-radius:12px;overflow:hidden}\n    .tbl-wrap{overflow-x:auto;-webkit-overflow-scrolling:touch}\n    /* during PNG export: expand to full width so the whole table is captured */\n    .pnl.export{width:max-content;max-width:none}\n    .pnl.export .tbl-wrap{overflow:visible}\n    .pnl-head{background:linear-gradient(135deg,var(--green-800),var(--green-700));color:#fff;padding:14px 18px}\n    .pnl-head .h1{font-size:17px;font-weight:800}\n    .pnl-head .sub{font-size:11.5px;color:#cfe8d3;margin-top:2px}\n    table{width:100%;border-collapse:collapse}\n    thead th{background:var(--green-100);border-bottom:2px solid var(--green-700);padding:10px 14px;font-size:12.5px;font-weight:700;white-space:nowrap;text-align:right}\n    thead th:first-child{text-align:left}\n    tbody td{padding:9px 14px;font-size:12.5px;white-space:nowrap;text-align:right;border-bottom:1px solid var(--line)}\n    tbody td:first-child{text-align:left;color:var(--ink)}\n    tbody tr.hl{background:var(--green-100)}\n    tbody tr.hl td{font-weight:700}\n    tbody tr.sub td:first-child{color:var(--muted);padding-left:26px;font-weight:500}\n    td.neg{color:var(--red)}\n    .pnl-foot{background:#f5f8f6;padding:7px 16px;text-align:right;font-size:10px;color:var(--muted);border-top:1px solid var(--line)}\n    pre{background:#0f2417;color:#cdeccf;border-radius:12px;padding:18px;font-size:12.5px;line-height:1.55;overflow:auto;max-height:520px;font-family:ui-monospace,SFMono-Regular,Menlo,monospace}\n    .toolbar{display:flex;gap:8px;flex-wrap:wrap;margin-top:14px}\n    /* error */\n    #error{display:none;text-align:center;padding:28px 10px}\n    .err-ico{width:54px;height:54px;border-radius:50%;background:#fdecea;color:var(--red);display:grid;place-items:center;font-size:26px;margin:0 auto 12px}\n    .err-msg{font-size:15px;font-weight:600;color:var(--red);margin-bottom:6px}\n    .err-sub{font-size:13px;color:var(--muted);margin-bottom:18px}\n    .toast{position:fixed;bottom:24px;left:50%;transform:translateX(-50%) translateY(20px);background:var(--green-800);color:#fff;padding:11px 18px;border-radius:10px;font-size:13px;font-weight:600;opacity:0;pointer-events:none;transition:.25s;box-shadow:var(--shadow)}\n    .toast.show{opacity:1;transform:translateX(-50%) translateY(0)}\n    footer{text-align:center;font-size:12px;color:var(--muted);margin-top:28px}\n    footer b{color:var(--green-800)}\n    @media (max-width:680px){\n      .wrap{padding:0 12px 48px}\n      .panel{padding:18px}\n      .brand h1{font-size:18px}\n      .row{flex-direction:column}\n      input[type=url],input[type=text]{min-width:0;width:100%}\n      .btn-primary{width:100%}\n      .company{font-size:17px}\n      .pnl-head .h1{font-size:15px}\n      thead th,tbody td{padding:8px 11px;font-size:12px}\n      pre{font-size:11.5px}\n    }\n  </style>\n</head>\n<body>\n  <header>\n    <div class=\"brand\">\n      <div class=\"logo\">🌱</div>\n      <div>\n        <h1>NIVESHAAY</h1>\n        <p>Automated Financial Results Processor</p>\n      </div>\n    </div>\n  </header>\n\n  <div class=\"wrap\">\n    <!-- INPUT -->\n    <div class=\"panel\" id=\"input-panel\">\n      <label class=\"fl\" for=\"url\">BSE / NSE corporate result PDF link</label>\n      <div class=\"row\">\n        <input id=\"url\" type=\"url\" placeholder=\"https://www.bseindia.com/xml-data/corpfiling/AttachHis/....pdf\" />\n        <button class=\"btn-primary\" id=\"go\" onclick=\"process()\">Extract P&amp;L →</button>\n      </div>\n      <div class=\"samples\">\n        Try a sample:\n        <a onclick=\"setUrl('https://www.bseindia.com/xml-data/corpfiling/AttachHis/ff349118-9b37-45cf-b26e-fdbcbf36acb4.pdf')\">Timex Group India (Q4 FY26)</a>\n      </div>\n      <div class=\"hint\">Paste a consolidated quarterly result PDF. The pipeline downloads it, extracts the P&amp;L with Gemini, and returns standardized JSON.</div>\n    </div>\n\n    <!-- LOADING -->\n    <div class=\"panel lift loader\" id=\"loader\">\n      <div class=\"spinner\"></div>\n      <div class=\"stage\" id=\"stage\">Processing…<small id=\"stage-sub\">Starting</small></div>\n    </div>\n\n    <!-- RESULT -->\n    <div class=\"panel lift\" id=\"result\">\n      <div class=\"resbar\">\n        <span class=\"company\" id=\"company\">Company</span>\n        <span class=\"badge\" id=\"qbadge\">standard</span>\n        <span class=\"spacer\"></span>\n        <button class=\"btn-ghost\" onclick=\"reset_()\">↺ Process another</button>\n      </div>\n      <div class=\"tabs\">\n        <div class=\"tab active\" data-t=\"table\" onclick=\"tab('table')\">📊 Table</div>\n        <div class=\"tab\" data-t=\"json\" onclick=\"tab('json')\">{ } JSON</div>\n        <div class=\"tab\" data-t=\"image\" onclick=\"tab('image')\">🖼 Image</div>\n      </div>\n\n      <div class=\"view active\" id=\"v-table\"></div>\n\n      <div class=\"view\" id=\"v-json\">\n        <pre id=\"json\"></pre>\n        <div class=\"toolbar\"><button class=\"btn-ghost\" onclick=\"copyJson()\">⧉ Copy JSON</button></div>\n      </div>\n\n      <div class=\"view\" id=\"v-image\">\n        <div id=\"card-wrap\"></div>\n        <div class=\"toolbar\"><button class=\"btn-ghost\" onclick=\"downloadPng()\">⬇ Download PNG</button></div>\n      </div>\n    </div>\n\n    <!-- ERROR -->\n    <div class=\"panel lift\" id=\"error\">\n      <div class=\"err-ico\">!</div>\n      <div class=\"err-msg\" id=\"err-msg\">Something went wrong</div>\n      <div class=\"err-sub\" id=\"err-sub\"></div>\n      <button class=\"btn-primary\" onclick=\"reset_()\">Try again</button>\n    </div>\n\n  </div>\n\n  <div class=\"toast\" id=\"toast\"></div>\n\n  <script>\n    var lastData = null;\n    var $ = function(id){ return document.getElementById(id); };\n    function setUrl(u){ $('url').value = u; $('url').focus(); }\n    function show(id){ ['input-panel','loader','result','error'].forEach(function(x){ $(x).style.display = (x===id?'block':'none'); }); }\n    function toast(msg){ var t=$('toast'); t.textContent=msg; t.classList.add('show'); setTimeout(function(){t.classList.remove('show');},1800); }\n\n    function tab(name){\n      ['table','json','image'].forEach(function(n){\n        document.querySelector('.tab[data-t=\"'+n+'\"]').classList.toggle('active', n===name);\n        $('v-'+n).classList.toggle('active', n===name);\n      });\n    }\n\n    var HL = ['revenue','gross profit','ebitda','total expenses','profit before tax','profit/loss before tax','pat','eps'];\n    function isHl(label){ var l=(label||'').toLowerCase(); return HL.some(function(k){ return l===k || l.indexOf(k)===0; }) || l.indexOf('ebitda')>-1 || l==='revenue'; }\n    function isNeg(v){ if(!v) return false; var c=String(v).replace(/[%,]/g,'').trim(); return !isNaN(parseFloat(c)) && parseFloat(c)<0; }\n\n    function rowsOf(data){ var r=[],i=1; while(data['row'+i]){ if(Array.isArray(data['row'+i])) r.push(data['row'+i].map(function(x){return x==null?'':String(x);})); i++; } return r; }\n\n    function buildTable(data){\n      var rows = rowsOf(data); if(!rows.length) return '<p>No rows.</p>';\n      var head = rows[0], body = rows.slice(1);\n      var th = head.map(function(h){ return '<th>'+esc(h)+'</th>'; }).join('');\n      var tr = body.map(function(r){\n        var label=r[0]||'', blank = r.slice(1).every(function(c){return c==='';});\n        var cls = isHl(label)?'hl':(blank?'sub':'');\n        var tds = r.map(function(c,idx){ var neg=(idx>0&&isNeg(c))?' class=\"neg\"':''; return '<td'+neg+'>'+esc(c)+'</td>'; }).join('');\n        return '<tr class=\"'+cls+'\">'+tds+'</tr>';\n      }).join('');\n      return '<table><thead><tr>'+th+'</tr></thead><tbody>'+tr+'</tbody></table>';\n    }\n\n    function buildCard(data){\n      var qt = data.quarter_type==='extended'?'Extended (Q2/Q4)':'Standard (Q1/Q3)';\n      return '<div class=\"pnl\" id=\"pnl-card\"><div class=\"pnl-head\"><div class=\"h1\">'+esc(data.company_name||'Unknown Company')+\n        '</div><div class=\"sub\">Quarterly Financial Results — '+qt+' · All values in ₹ Crores</div></div><div class=\"tbl-wrap\">'+\n        buildTable(data)+'</div><div class=\"pnl-foot\">Generated by Niveshaay Financial Results Processor</div></div>';\n    }\n\n    function esc(s){ return String(s==null?'':s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/\"/g,'&quot;'); }\n\n    function render(data){\n      lastData = data;\n      $('company').textContent = data.company_name || 'Unknown Company';\n      $('qbadge').textContent = data.quarter_type || '—';\n      $('v-table').innerHTML = '<div class=\"pnl\"><div class=\"pnl-head\"><div class=\"h1\">'+esc(data.company_name||'')+'</div><div class=\"sub\">All values in ₹ Crores</div></div><div class=\"tbl-wrap\">'+buildTable(data)+'</div></div>';\n      $('json').textContent = JSON.stringify(data, null, 2);\n      $('card-wrap').innerHTML = buildCard(data);\n      tab('table');\n      show('result');\n    }\n\n    function copyJson(){\n      navigator.clipboard.writeText(JSON.stringify(lastData, null, 2)).then(function(){ toast('JSON copied ✓'); },\n        function(){ toast('Copy failed'); });\n    }\n\n    function downloadPng(){\n      var el = $('pnl-card'); if(!el || !window.html2canvas){ toast('Image lib not loaded'); return; }\n      el.classList.add('export');   // expand to full width so the whole table is captured\n      html2canvas(el, {scale:2, backgroundColor:'#ffffff'}).then(function(canvas){\n        el.classList.remove('export');\n        var a=document.createElement('a');\n        a.download = ((lastData&&lastData.company_name)||'pnl').replace(/[^a-z0-9]+/gi,'_')+'.png';\n        a.href = canvas.toDataURL('image/png'); a.click(); toast('Image downloaded ✓');\n      }).catch(function(){ el.classList.remove('export'); toast('Image export failed'); });\n    }\n\n    function reset_(){ $('url').value=''; show('input-panel'); $('url').focus(); }\n\n    var STAGES = [[0,'Downloading PDF…','Fetching the document from BSE/NSE'],[1,'Extracting with Gemini…','Reading the consolidated P&L (this takes ~30–60s)'],[2,'Building result…','Formatting the standardized JSON']];\n    var stageTimer=null;\n    function runStages(){ var i=0; $('stage').firstChild.textContent=STAGES[0][1]; $('stage-sub').textContent=STAGES[0][2];\n      stageTimer=setInterval(function(){ i=Math.min(i+1,STAGES.length-1); $('stage').firstChild.textContent=STAGES[i][1]; $('stage-sub').textContent=STAGES[i][2]; }, 9000); }\n    function stopStages(){ if(stageTimer) clearInterval(stageTimer); stageTimer=null; }\n\n    function process(){\n      var url = $('url').value.trim();\n      if(!url){ toast('Please paste a PDF link'); $('url').focus(); return; }\n      $('go').disabled = true; show('loader'); runStages();\n      fetch('/webhook/process-pdf', {\n        method:'POST', headers:{'Content-Type':'application/json'}, body: JSON.stringify({ pdfUrl: url })\n      }).then(function(res){ return res.json().then(function(j){ return {ok:res.ok, status:res.status, j:j}; }); })\n      .then(function(r){\n        stopStages(); $('go').disabled = false;\n        if(r.j && r.j.success && r.j.data){ render(r.j.data); }\n        else { showError((r.j && (r.j.error||r.j.message)) || ('Request failed ('+r.status+')')); }\n      }).catch(function(e){ stopStages(); $('go').disabled=false; showError('Network error — is the n8n workflow active? '+e.message); });\n    }\n\n    function showError(msg){\n      $('err-msg').textContent = msg;\n      $('err-sub').textContent = 'Check the link is a valid https PDF, or try another filing.';\n      show('error');\n    }\n\n    // submit on Enter\n    document.addEventListener('keydown', function(e){ if(e.key==='Enter' && document.activeElement===$('url')) process(); });\n  </script>\n</body>\n</html>\n",
        "options": {
          "responseHeaders": {
            "entries": [
              {
                "name": "Content-Type",
                "value": "text/html; charset=utf-8"
              }
